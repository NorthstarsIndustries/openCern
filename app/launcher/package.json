{
  "name": "opencern-launcher",
  "private": true,
  "version": "1.0.0",
  "description": "OpenCERN Desktop Launcher — manage CERN Open Data containers and analysis tools",
  "author": {
    "name": "NorthStars Industries",
    "email": "contact@northstarcorp.co"
  },
  "homepage": "https://github.com/NorthstarsIndustries/openCern",
  "repository": {
    "type": "git",
    "url": "https://github.com/NorthstarsIndustries/openCern.git"
  },
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"next dev -p 3001\" \"wait-on http://localhost:3001 && electron .\"",
    "build": "next build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.opencern.launcher",
    "productName": "OpenCERN",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron-dist/**/*",
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.education",
      "icon": "public/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Science",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockerode": "^4.0.4",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/dockerode": "^3.3.38",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "wait-on": "^8.0.0"
  }
}

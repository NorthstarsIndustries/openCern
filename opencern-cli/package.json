{
  "name": "@opencern/cli",
  "version": "1.0.0-beta.1",
  "description": "OpenCERN Terminal — AI-powered particle physics analysis with quantum computing",
  "author": "NorthStars Industries",
  "license": "MIT",
  "bin": {
    "opencern": "./bin/opencern.js"
  },
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "bun run --watch src/app.tsx",
    "build": "tsc",
    "start": "bun bin/opencern.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@opentui/core": "0.1.88",
    "@opentui/solid": "0.1.88",
    "axios": "^1.7.0",
    "chalk": "^5.4.0",
    "cli-highlight": "^2.1.0",
    "conf": "^13.0.0",
    "figures": "^6.1.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-preset-solid": "^1.9.10",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "cern",
    "particle-physics",
    "quantum-computing",
    "ai",
    "claude",
    "cli",
    "terminal",
    "tui",
    "hep",
    "root",
    "qiskit"
  ]
}
